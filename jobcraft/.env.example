# ─── JobCraft Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values:
#   copy .env.example .env   (Windows)
#   cp .env.example .env    (Mac/Linux)

# ★ Recommended for best resume quality: OpenAI API key (paid, usage-based)
# Get it at: https://platform.openai.com/api-keys
# Key usually starts with "sk-..." (not Anthropic "sk-ant-...")
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# AI_PROVIDER=openai
# Or use AI_PROVIDER=auto to prefer OpenAI when OPENAI_API_KEY is set, else Gemini, else Ollama.

# ★ FREE: Google Gemini API key (no credit card required)
# Get it at: https://aistudio.google.com → Get API key → Create API key
# Key starts with "AIza..."
GEMINI_API_KEY=AIza-your-free-key-here

# ★ FREE & UNLIMITED (local): Ollama (no API keys, no quotas)
# 1) Install Ollama: https://ollama.com
# 2) Pull a model once:   ollama pull llama3.1
# 3) Start the server:    ollama serve
# Then set:
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
# OLLAMA_TIMEOUT_SECONDS=120

# Optional: Anthropic Claude (paid). If you set this, it is used when the key above is not set.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Gemini model (free tier). Default is fine.
# GEMINI_MODEL=gemini-1.5-flash

# Secret key for JWT tokens — change to any long random string
SECRET_KEY=change-this-to-a-very-long-random-string-abc123

# Production: comma-separated browser origins allowed to call the API (your Vercel URL, custom domain)
# CORS_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# Public demo API (no JWT): set True only for a dedicated demo backend — insecure for real data
# PUBLIC_DEMO_MODE=false

# Default admin account (change password after first login!)
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=jobcraft2024
